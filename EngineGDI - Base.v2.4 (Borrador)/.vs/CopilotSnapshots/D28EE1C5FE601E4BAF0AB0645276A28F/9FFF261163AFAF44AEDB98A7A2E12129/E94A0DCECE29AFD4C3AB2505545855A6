using System;
using System.Collections.Generic;
using System.Drawing;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace EngineGDI
{
    public class Animation
    {
        private bool isLoop;
        private string name;
        private float speed;
        private float currentTime;
        private float currentFrame = 0;
        private readonly List<Texture> textures = new List<Texture>();

        public Texture CurrentTexture => textures[currentFrame];

        public Animation(string name, List<Texture> textures, float speed, bool isLoop = true)
        {
            this.name = name;
            this.speed = speed;
            this.isLoop = isLoop;
            this.currentFrame = 0;

            if (textures != null) 
            {
                this.textures = textures;
            }
        }

        public void Update() 
        {
            currentTime += Program.deltaTime;

            if (currentTime >= 0)
            {
                currentTime = 0f;
                currentFrame++;

                if (currentFrame >= textures.Count) 
                {
                    if (isLoop) 
                    {
                        currentFrame = 0;
                    }
                    else 
                    {
                        currentFrame = textures.Count - 1;
                    }
                }
            }
        }

    }
}
